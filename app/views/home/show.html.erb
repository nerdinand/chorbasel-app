<% content_for :title, t('.title') %>

<% if @home.has_info? %>
  <%= render @home.info %>
<% end %>

<%= render partial: 'profile_completeness' %>

<% if @home.has_attendances? %>
  <%= render partial: 'attendances', locals: { attendances: @home.attendances } %>
<% end %>

<%= render partial: 'upcoming_birthdays', locals: {upcoming_birthdays: @home.upcoming_birthdays} %>
<%= render partial: 'calendar', locals: {calendar_events: @home.calendar_events} %>
