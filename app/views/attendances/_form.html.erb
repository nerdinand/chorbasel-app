<%# i18n-tasks-use t('activerecord.models.attendance') %>
<%= render 'errors', model: @attendance %>

<div class='form-field'>
  <p><%= label_tag t('activerecord.attributes.attendance.user') %>: <b><%= @attendance.user.full_name %></b></p>
</div>

<div class='form-field'>
  <p><%= label_tag t('activerecord.attributes.attendance.calendar_event') %>: <%= render 'application/calendar_event', calendar_event: @attendance.calendar_event %></p>
</div>

<%= form_for @attendance, url: attendance_acceptance_path(@attendance), method: :post do |f| %>
  <%= f.submit t('.acceptance.create'), class: 'btn btn-secondary' %>
<% end %>

<%= form_for @attendance do |f| %>
  <%= f.hidden_field :user_id %>
  <%= f.hidden_field :calendar_event_id %>

  <div class='form-field'>
    <p><%= f.label :status %> <%# i18n-tasks-use t('activerecord.attributes.attendance.status') %></p>
    <%= f.select :status, attendances_status_options %>
  </div>
  
  <div class='form-field'>
    <p><%= f.label :remarks %> <%# i18n-tasks-use t('activerecord.attributes.attendance.remarks') %></p>
    <%= f.text_area :remarks %>
  </div>

  <p><%= f.submit class: 'btn btn-primary' %> <%# i18n-tasks-use t('helpers.submit.attendance.create') %></p>
<% end %>
